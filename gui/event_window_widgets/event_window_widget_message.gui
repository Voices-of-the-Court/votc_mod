hbox = {
	name = "event_window_widget_message"
	layoutpolicy_horizontal = expanding
	margin = { 10 0 }

	state = {
        name = widget_show
        trigger_on_create = yes

		on_finish = "[ExecuteConsoleCommand('gui.createwidget gui/custom_gui/letters_runner.gui letters_runner')]"	
	
	}


	expand = {}
} 